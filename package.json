{
  "name": "poi-plugin-kan-recomentation",
  "version": "0.1.0",
  "private": true,
  "description": "Poi plugin that recommends which ships to level next from an inventory export CSV",
  "license": "MIT",
  "author": {
    "name": "kwt-klure"
  },
  "keywords": [
    "poi",
    "plugin",
    "kancolle",
    "recommendation",
    "remodel",
    "training"
  ],
  "files": [
    "src/App.tsx",
    "src/Settings.tsx",
    "src/index.ts",
    "src/poi",
    "src/recommendation",
    "i18n",
    "package.json",
    "README.md"
  ],
  "main": "src/index.ts",
  "scripts": {
    "build": "npm run typeCheck",
    "test": "jest",
    "typeCheck": "tsc --noEmit"
  },
  "dependencies": {
    "@blueprintjs/core": "^5.7.2",
    "@blueprintjs/icons": "^5.7.2",
    "i18next": "^19.8.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^11.8.5",
    "styled-components": "^6.1.13",
    "stylis": "^4.3.4"
  },
  "devDependencies": {
    "@babel/core": "^7.12.10",
    "@babel/preset-env": "^7.23.2",
    "@babel/preset-react": "^7.22.15",
    "@babel/preset-typescript": "^7.23.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.3"
  },
  "poiPlugin": {
    "title": "Kan Recomentation",
    "description": "Recommend which ships to level next from your current roster",
    "icon": "fa/compass",
    "i18nDir": "./i18n",
    "priority": 2,
    "apiVer": {}
  },
  "packageManager": "npm@11.6.0"
}
